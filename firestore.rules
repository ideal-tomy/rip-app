rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 認証必須（匿名認証含む）
    match /events/{eventId} {
      allow read, write: if request.auth != null;

      match /orders/{orderId} {
        allow read, write: if request.auth != null;
      }

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }

      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
